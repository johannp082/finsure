# ─────────────────────────────────────────────────────────────
# Secrets & environment files — NEVER commit these
# ─────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.pfx
# Scoped to data files only — must NOT match source like secret_resolver.py
secrets.json
secrets.yaml
secrets.yml
**/local.settings.json

# ─────────────────────────────────────────────────────────────
# Terraform — state can contain secrets in plain text
# ─────────────────────────────────────────────────────────────
**/.terraform/*
*.tfstate
*.tfstate.*
crash.log
crash.*.log
!*.tfvars
!*.tfvars.example
override.tf
override.tf.json
*_override.tf
*_override.tf.json
# NOTE: .terraform.lock.hcl is intentionally NOT ignored — commit it to pin provider versions

# ─────────────────────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/

# ─────────────────────────────────────────────────────────────
# Editors / OS
# ─────────────────────────────────────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
**/.cursor/*
**/.cursor-plugin/*

# ─────────────────────────────────────────────────────────────
# Docker
# ─────────────────────────────────────────────────────────────
*.log
