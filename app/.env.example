# Copy this file to ".env" for local development:  cp .env.example .env
# The .env file is git-ignored and must NEVER be committed.

# ── Environment ────────────────────────────────────────────────
APP_ENV=dev
LOG_LEVEL=INFO

# ── Easiest way to run locally: mock mode (no real vendor needed) ──
# Set to true to return deterministic fake scores with zero setup.
USE_MOCK=true

# ── RiskShield vendor API (used when USE_MOCK=false) ──────────────
RISKSHIELD_API_URL=https://api.riskshield.com/v1/score
# For LOCAL dev only. In Azure this comes from Key Vault instead.
RISKSHIELD_API_KEY=replace-with-your-dev-key

# ── Resilience tuning ─────────────────────────────────────────────
HTTP_TIMEOUT_SECONDS=5
HTTP_MAX_RETRIES=3
HTTP_BACKOFF_SECONDS=0.5

# ── Azure Key Vault (leave blank locally; set by Terraform in Azure) ──
# KEY_VAULT_URI=https://kv-yourname.vault.azure.net/
KEY_VAULT_SECRET_NAME=riskshield-api-key
